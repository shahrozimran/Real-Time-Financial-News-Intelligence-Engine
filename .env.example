# ============================================================
# Real-Time Financial News Intelligence Engine
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# ============================================================

# ── Week 1: Live Data API Keys ────────────────────────────────
# Finnhub (news + stock quotes): https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage (crypto + index prices): https://www.alphavantage.co/
ALPHAVANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ApeWisdom (Reddit social sentiment) — no API key required
# APEWISDOM_API_KEY=

# ── Week 3: Vector DB + LLM API Keys ─────────────────────────
# Pinecone (vector database): https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=finintel

# OpenRouter (LLM + embeddings): https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use via OpenRouter
LLM_MODEL=openai/gpt-4o-mini

# Embedding model for Pinecone vectors
EMBEDDING_MODEL=openai/text-embedding-3-small

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092

# ── Flask ──────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ── PySpark ────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_LOG_LEVEL=WARN

# ── Streaming Pipeline ─────────────────────────────────────────
# How often (seconds) each streaming micro-batch is triggered
STREAMING_TRIGGER_SECONDS=30

# Checkpoint directory for Structured Streaming fault tolerance
# STREAMING_CHECKPOINT_DIR=data/checkpoints
